APP_NAME=Bambam Converter Suite Web
APP_ENV=production
API_HOST=0.0.0.0
API_PORT=8000

# Replace with your real frontend origin(s).
# IP-only example:
# CORS_ORIGINS=["http://YOUR_VDS_IP:3000"]
# Domain example:
# CORS_ORIGINS=["https://bambam.example.com"]
CORS_ORIGINS=["http://YOUR_VDS_IP:3000"]

REDIS_URL=redis://redis:6379/0

# Upload and queue behavior
MAX_UPLOAD_SIZE_MB=250
QUEUE_DEFAULT_TIMEOUT=30m
QUEUE_VIDEO_TIMEOUT=120m
QUEUE_DOCUMENT_TIMEOUT=60m
